spring.application.name=chatbot_backend
# Spring AI OpenAI SDK configuration (Azure OpenAI / Microsoft Foundry via openai.azure.com endpoint)
spring.ai.openai-sdk.base-url=
spring.ai.openai-sdk.api-key=
spring.ai.openai-sdk.chat.options.model=
spring.ai.openai-sdk.image.options.model=
# Database configuration
spring.datasource.url=
spring.datasource.username=
spring.datasource.password=

spring.jpa.properties.hibernate.dialect=
spring.jpa.hibernate.ddl-auto=update
# JWT configuration
jwt.secret=
# Email configuration
spring.mail.host=
spring.mail.port=587
spring.mail.username=
spring.mail.password=
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
# Application URLs
app.backend-base-url=${BACKEND_BASE_URL:http://localhost:8080/api/v1}
app.frontend-base-url=${FRONTEND_BASE_URL:http://localhost:5173}
